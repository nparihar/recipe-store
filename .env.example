# Password to access the app (change this!)
APP_PASSWORD=your-secure-password

# Secret for signing JWT tokens (generate a random string)
JWT_SECRET=your-random-jwt-secret-here

# Google Gemini API key for AI recipe import
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Port (default 3000)
PORT=3000

# Database path (default: ./data/recipes.db)
DB_PATH=./data/recipes.db

# Uploads directory (default: ./data/uploads)
UPLOADS_DIR=./data/uploads
